{
  "id": "0036_flights_two_routes",
  "category": "parallel_tools",
  "difficulty": "hard",
  "prompt": "Compare one-way options for 1 passenger on 2026-11-20: search JFK to LHR, and separately search EWR to LHR. Two searches, no return date.",
  "system_prompt": "",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "search_flights",
        "description": "Search flights between airports. Airports use 3-letter uppercase IATA codes. Dates use YYYY-MM-DD.",
        "parameters": {
          "type": "object",
          "properties": {
            "origin": {
              "type": "string",
              "description": "Origin airport IATA code, e.g. 'SFO'."
            },
            "destination": {
              "type": "string",
              "description": "Destination airport IATA code, e.g. 'NRT'."
            },
            "departure_date": {
              "type": "string",
              "description": "Departure date, format YYYY-MM-DD."
            },
            "return_date": {
              "type": "string",
              "description": "Optional return date for round trips, YYYY-MM-DD."
            },
            "passengers": {
              "type": "integer",
              "description": "Number of passengers."
            }
          },
          "required": [
            "origin",
            "destination",
            "departure_date",
            "passengers"
          ],
          "additionalProperties": false
        }
      }
    }
  ],
  "expected_tool_calls": [
    {
      "name": "search_flights",
      "arguments": {
        "origin": "JFK",
        "destination": "LHR",
        "departure_date": "2026-11-20",
        "passengers": 1
      }
    },
    {
      "name": "search_flights",
      "arguments": {
        "origin": "EWR",
        "destination": "LHR",
        "departure_date": "2026-11-20",
        "passengers": 1
      }
    }
  ],
  "scoring": {
    "require_exact_tool_names": true,
    "require_exact_arguments": true,
    "allow_extra_tool_calls": false,
    "require_order": false,
    "allow_argument_coercion": false,
    "trim_string_whitespace": true
  },
  "notes": "Two one-way searches; adding a return_date is an argument error."
}
