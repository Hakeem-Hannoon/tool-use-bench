{
  "id": "0049_ticket_priority_enum",
  "category": "argument_precision",
  "difficulty": "medium",
  "prompt": "Open an urgent support ticket for sam.lee@example.com. Subject: 'Cannot access account'. Description: 'User reports 2FA codes are never delivered.'",
  "system_prompt": "",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "create_support_ticket",
        "description": "Create a customer support ticket.",
        "parameters": {
          "type": "object",
          "properties": {
            "subject": {
              "type": "string",
              "description": "Short ticket subject."
            },
            "description": {
              "type": "string",
              "description": "Full description of the problem."
            },
            "priority": {
              "type": "string",
              "description": "Ticket priority.",
              "enum": [
                "low",
                "medium",
                "high",
                "urgent"
              ]
            },
            "customer_email": {
              "type": "string",
              "description": "Optional customer email address."
            }
          },
          "required": [
            "subject",
            "description",
            "priority"
          ],
          "additionalProperties": false
        }
      }
    }
  ],
  "expected_tool_calls": [
    {
      "name": "create_support_ticket",
      "arguments": {
        "subject": "Cannot access account",
        "description": "User reports 2FA codes are never delivered.",
        "priority": "urgent",
        "customer_email": "sam.lee@example.com"
      }
    }
  ],
  "scoring": {
    "require_exact_tool_names": true,
    "require_exact_arguments": true,
    "allow_extra_tool_calls": false,
    "require_order": true,
    "allow_argument_coercion": false,
    "trim_string_whitespace": true
  },
  "notes": "The word 'urgent' must map to the exact enum value, and the optional customer_email must be included."
}
