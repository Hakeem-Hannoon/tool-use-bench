{
  "id": "0010_file_search_pdf",
  "category": "single_tool",
  "difficulty": "medium",
  "prompt": "Search my files for PDFs matching 'quarterly report'. Limit to 10 results.",
  "system_prompt": "",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "search_files",
        "description": "Search files in cloud storage.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Keyword to search file names and contents."
            },
            "file_type": {
              "type": "string",
              "description": "File type filter.",
              "enum": [
                "pdf",
                "docx",
                "xlsx",
                "txt",
                "any"
              ]
            },
            "max_results": {
              "type": "integer",
              "description": "Optional maximum number of results."
            }
          },
          "required": [
            "query",
            "file_type"
          ],
          "additionalProperties": false
        }
      }
    }
  ],
  "expected_tool_calls": [
    {
      "name": "search_files",
      "arguments": {
        "query": "quarterly report",
        "file_type": "pdf",
        "max_results": 10
      }
    }
  ],
  "scoring": {
    "require_exact_tool_names": true,
    "require_exact_arguments": true,
    "allow_extra_tool_calls": false,
    "require_order": true,
    "allow_argument_coercion": false,
    "trim_string_whitespace": true
  },
  "notes": "Tests an enum file type plus an optional integer limit that the prompt makes required."
}
